rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile: only the user can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Nested collections inside user doc
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
